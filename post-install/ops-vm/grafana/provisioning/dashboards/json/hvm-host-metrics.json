        "expr": "100 * (1 - avg by(instance) (irate(node_cpu_seconds_total{job=\"node_exporter\", instance=~\"$instance\", mode=\"idle\"}[$__rate_interval])))",
        "refId": "A"
      }],
      "title": "CPU",
      "type": "stat"
